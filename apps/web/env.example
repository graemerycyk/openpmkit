# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pmkit?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# OAuth - Google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OAuth - Microsoft
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID="common"

# Storage (S3-compatible - DigitalOcean Spaces)
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_REGION="us-east-1"

# Analytics & Webmaster Tools
NEXT_PUBLIC_SIMPLE_ANALYTICS_DOMAIN="sa.getpmkit.com"
NEXT_PUBLIC_GSC_VERIFICATION=""
NEXT_PUBLIC_BING_VERIFICATION=""

# LLM (for real mode)
OPENAI_API_KEY=""

# Feature Flags
USE_STUB_LLM="true"
USE_LOCAL_STORAGE="true"

