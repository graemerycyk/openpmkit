# =============================================================================
# Database
# =============================================================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pmkit?schema=public"

# Redis (for job queue / caching)
REDIS_URL="redis://localhost:6379"

# =============================================================================
# NextAuth (User Authentication)
# =============================================================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# =============================================================================
# SSO OAuth Providers (Teams plan: OIDC)
# =============================================================================

# Google Workspace
# Create at: https://console.cloud.google.com/ → APIs & Services → Credentials
# Redirect URI: https://app.getpmkit.com/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Microsoft Entra ID (Azure AD)
# Create at: https://portal.azure.com/ → App registrations
# Redirect URI: https://app.getpmkit.com/api/auth/callback/azure-ad
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID="common"

# =============================================================================
# Stripe Billing
# =============================================================================
# Get keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Create Products & Prices in Stripe Dashboard:
# - Teams Plan: $900/year per seat (annual, per_unit)
STRIPE_TEAMS_PRICE_ID=""

# =============================================================================
# MCP Connector OAuth Apps
# =============================================================================

# Atlassian (Jira + Confluence)
# Create at: https://developer.atlassian.com/console/myapps/
# Scopes: read:jira-work, write:jira-work, read:confluence-content.all, write:confluence-content
# Redirect URI: https://app.getpmkit.com/api/connectors/atlassian/callback
ATLASSIAN_CLIENT_ID=""
ATLASSIAN_CLIENT_SECRET=""

# Slack
# Create at: https://api.slack.com/apps
# Scopes: channels:history, channels:read, chat:write, users:read, search:read
# Redirect URI: https://app.getpmkit.com/api/connectors/slack/callback
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""
SLACK_SIGNING_SECRET=""

# Gong
# Contact Gong for API access or use: https://developer.gong.io/
# Redirect URI: https://app.getpmkit.com/api/connectors/gong/callback
GONG_CLIENT_ID=""
GONG_CLIENT_SECRET=""

# Zendesk
# Create at: Admin Center → Apps and integrations → APIs → OAuth Clients
# Redirect URI: https://app.getpmkit.com/api/connectors/zendesk/callback
ZENDESK_CLIENT_ID=""
ZENDESK_CLIENT_SECRET=""

# Encryption key for storing connector credentials (generate with: openssl rand -base64 32)
CONNECTOR_ENCRYPTION_KEY=""

# =============================================================================
# Object Storage (S3-compatible)
# =============================================================================
# For artifact storage (PRDs, briefs, meeting packs)
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_REGION="us-east-1"

# =============================================================================
# LLM Provider
# =============================================================================

# OpenAI (default)
OPENAI_API_KEY=""
OPENAI_ORG_ID=""

# Azure OpenAI (Enterprise BYO - optional)
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_DEPLOYMENT_NAME=""

# =============================================================================
# Email (Transactional)
# =============================================================================
# For notifications, invites, receipts
RESEND_API_KEY=""
EMAIL_FROM="pmkit <noreply@getpmkit.com>"

# =============================================================================
# Analytics & Monitoring
# =============================================================================

# Simple Analytics (privacy-friendly)
NEXT_PUBLIC_SIMPLE_ANALYTICS_DOMAIN="sa.getpmkit.com"

# Search Console / Webmaster Tools
NEXT_PUBLIC_GSC_VERIFICATION=""
NEXT_PUBLIC_BING_VERIFICATION=""

# PostHog (product analytics - optional)
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.posthog.com"

# Sentry (error tracking - optional)
SENTRY_DSN=""

# =============================================================================
# Feature Flags
# =============================================================================

# Use mock LLM responses (for local development only)
USE_STUB_LLM="true"

# Use local file storage instead of S3 (for local development only)
USE_LOCAL_STORAGE="true"

# =============================================================================
# Notes on Demo vs Real Connectors
# =============================================================================
# 
# The demo (tenant ID: "demo") ALWAYS uses mock connectors - no OAuth needed.
# This powers the public demo at /demo with realistic mock data.
#
# Real paying customers get connectors based on their install status:
# - status='mock': Connector installed but OAuth not connected (uses mock data)
# - status='real': OAuth connected (uses real MCP connection)
#
# When a customer connects OAuth, their connector switches from mock to real.
# No global flag needed - it's per-tenant, per-connector.
