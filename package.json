{
  "name": "openpmkit",
  "version": "1.0.0",
  "private": true,
  "description": "Open-source AI Product Management toolkit - 10 autonomous workflows for PMs",
  "workspaces": [
    "apps/*",
    "packages/*",
    "pmkit-desktop"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "npm run start --workspace=apps/web",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,mdx}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,mdx}\""
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "npm@10.2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/openpmkit/openpmkit.git"
  },
  "keywords": [
    "openpmkit",
    "product-management",
    "ai",
    "cli",
    "workflows",
    "byok"
  ],
  "author": "openpmkit",
  "license": "MIT"
}
