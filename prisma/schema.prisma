// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Tenant & User Models
// ============================================================================

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  jobs               Job[]
  toolCalls          ToolCall[]
  proposals          Proposal[]
  artifacts          Artifact[]
  sources            Source[]
  auditLogs          AuditLog[]
  subscription       Subscription?
  seatAssignments    SeatAssignment[]
  entitlements       Entitlement[]
  usageEvents        UsageEvent[]
  usageRollupsDaily  UsageRollupDaily[]
  ssoConnections     SSOConnection[]
  scimDirectories    SCIMDirectory[]
  groupRoleMappings  GroupRoleMapping[]
  connectorInstalls  ConnectorInstall[]
  connectorPolicies  ConnectorPolicy[]
  policyDecisionLogs PolicyDecisionLog[]
  agentConfigs       AgentConfig[]

  @@map("tenants")
}

model User {
  id          String   @id @default(cuid())
  tenantId    String
  email       String
  name        String
  avatarUrl   String?
  role        UserRole @default(viewer)
  permissions String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  jobs              Job[]
  proposals         Proposal[] @relation("ProposalCreator")
  reviews           Proposal[] @relation("ProposalReviewer")
  auditLogs         AuditLog[]
  seatAssignment    SeatAssignment?
  usageEvents       UsageEvent[]
  connectorInstalls ConnectorInstall[]
  agentConfigs      AgentConfig[]

  @@unique([tenantId, email])
  @@map("users")
}

enum UserRole {
  admin
  pm
  eng
  cs
  sales
  exec
  viewer
  guest
}

// ============================================================================
// Billing & Subscription Models
// ============================================================================

enum PlanKey {
  TEAMS
  ENTERPRISE
}

model Subscription {
  id                   String             @id @default(cuid())
  tenantId             String             @unique
  planKey              PlanKey
  status               SubscriptionStatus @default(active)
  seatsPurchased       Int
  billingProvider      String             @default("stripe")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@map("subscriptions")
}

enum SubscriptionStatus {
  active
  past_due
  canceled
  trialing
  paused
}

model SeatAssignment {
  id        String               @id @default(cuid())
  tenantId  String
  userId    String               @unique
  status    SeatAssignmentStatus @default(active)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@map("seat_assignments")
}

enum SeatAssignmentStatus {
  active
  inactive
  pending
}

model Entitlement {
  id        String   @id @default(cuid())
  tenantId  String
  key       String
  valueJson Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@map("entitlements")
}

// ============================================================================
// Usage Analytics Models
// ============================================================================

model UsageEvent {
  id              String   @id @default(cuid())
  tenantId        String
  userId          String?
  jobRunId        String?
  eventType       String
  units           Int      @default(1)
  costEstimateUsd Decimal? @db.Decimal(10, 6)
  metaJson        Json?
  createdAt       DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, eventType])
  @@index([userId, createdAt])
  @@map("usage_events")
}

model UsageRollupDaily {
  id         String   @id @default(cuid())
  tenantId   String
  date       DateTime @db.Date
  totalsJson Json

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date])
  @@map("usage_rollups_daily")
}

// ============================================================================
// SSO & Directory Models
// ============================================================================

model SSOConnection {
  id              String          @id @default(cuid())
  tenantId        String
  type            SSOType
  provider        String
  domainAllowlist String[]
  metadataJson    Json?
  status          SSOStatus       @default(pending)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
  @@map("sso_connections")
}

enum SSOType {
  OIDC
  SAML
}

enum SSOStatus {
  pending
  active
  disabled
}

model GroupRoleMapping {
  id              String   @id @default(cuid())
  tenantId        String
  externalGroupId String
  role            UserRole
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, externalGroupId])
  @@map("group_role_mappings")
}

model SCIMDirectory {
  id         String     @id @default(cuid())
  tenantId   String     @unique
  provider   String
  status     SCIMStatus @default(pending)
  configJson Json?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("scim_directories")
}

enum SCIMStatus {
  pending
  active
  disabled
}

// ============================================================================
// Connector Models
// ============================================================================

model ConnectorInstall {
  id           String          @id @default(cuid())
  tenantId     String
  connectorKey String
  status       ConnectorStatus @default(mock)
  createdBy    String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  tenant      Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator     User                  @relation(fields: [createdBy], references: [id])
  credentials ConnectorCredential[]

  @@unique([tenantId, connectorKey])
  @@map("connector_installs")
}

enum ConnectorStatus {
  mock
  real
  disabled
}

model ConnectorCredential {
  id            String    @id @default(cuid())
  installId     String
  encryptedBlob String    @db.Text
  scopesJson    Json?
  expiresAt     DateTime?
  refreshable   Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  install ConnectorInstall @relation(fields: [installId], references: [id], onDelete: Cascade)

  @@index([installId])
  @@map("connector_credentials")
}

model ConnectorPolicy {
  id                  String   @id @default(cuid())
  tenantId            String
  connectorKey        String
  allowedToolsJson    Json?
  allowedResourcesJson Json?
  proposalOnly        Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, connectorKey])
  @@map("connector_policies")
}

// ============================================================================
// Policy Decision Log
// ============================================================================

model PolicyDecisionLog {
  id          String         @id @default(cuid())
  tenantId    String
  jobRunId    String?
  toolCallId  String?
  decision    PolicyDecision
  reason      String
  ruleMatched String?
  createdAt   DateTime       @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([jobRunId])
  @@map("policy_decision_logs")
}

enum PolicyDecision {
  ALLOW
  DENY
}

// ============================================================================
// Agent Config Models
// ============================================================================

model AgentConfig {
  id        String    @id @default(cuid())
  userId    String
  tenantId  String
  agentType String    // 'daily_brief', etc.
  status    String    @default("active") // 'active', 'paused'
  config    Json      // Agent-specific config (e.g., { dataTimeframeHours, deliveryTimeLocal, timezone, slackChannels })
  nextRunAt DateTime?
  lastRunAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, agentType])
  @@index([tenantId])
  @@index([status, nextRunAt])
  @@map("agent_configs")
}

// ============================================================================
// Job Models
// ============================================================================

model Job {
  id          String    @id @default(cuid())
  tenantId    String
  type        JobType
  status      JobStatus @default(pending)
  triggeredBy String
  config      Json?
  result      Json?
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [triggeredBy], references: [id])
  toolCalls ToolCall[]
  proposals Proposal[]
  artifacts Artifact[]

  @@index([tenantId, status])
  @@index([tenantId, type])
  @@map("jobs")
}

enum JobType {
  daily_brief
  meeting_prep
  voc_clustering
  competitor_research
  roadmap_alignment
  prd_draft
  sprint_review
  prototype_generation
  release_notes
  deck_content
}

enum JobStatus {
  pending
  queued
  running
  completed
  failed
  cancelled
}

// ============================================================================
// Tool Call Models (MCP)
// ============================================================================

model ToolCall {
  id         String         @id @default(cuid())
  jobId      String
  tenantId   String
  toolName   String
  serverName String
  input      Json
  output     Json?
  status     ToolCallStatus @default(pending)
  durationMs Int?
  error      String?
  createdAt  DateTime       @default(now())

  job    Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([tenantId, createdAt])
  @@map("tool_calls")
}

enum ToolCallStatus {
  pending
  success
  error
  skipped
}

// ============================================================================
// Proposal Models (Draft-Only Pattern)
// ============================================================================

model Proposal {
  id           String         @id @default(cuid())
  tenantId     String
  jobId        String
  type         ProposalType
  status       ProposalStatus @default(draft)
  title        String
  preview      String         @db.Text
  diff         String?        @db.Text
  bundle       Json
  targetSystem String
  targetId     String?
  createdBy    String
  reviewedBy   String?
  reviewedAt   DateTime?
  expiresAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  job      Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  creator  User   @relation("ProposalCreator", fields: [createdBy], references: [id])
  reviewer User?  @relation("ProposalReviewer", fields: [reviewedBy], references: [id])

  @@index([tenantId, status])
  @@index([jobId])
  @@map("proposals")
}

enum ProposalType {
  jira_epic
  jira_story
  confluence_page
  slack_message
  prd_document
  release_notes
}

enum ProposalStatus {
  draft
  pending_review
  approved
  rejected
  expired
}

// ============================================================================
// Artifact Models
// ============================================================================

model Artifact {
  id         String       @id @default(cuid())
  tenantId   String
  jobId      String
  type       ArtifactType
  title      String
  format     String       @default("markdown")
  content    String       @db.Text
  metadata   Json?
  storageKey String?
  expiresAt  DateTime?
  createdAt  DateTime     @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  job    Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([tenantId, type])
  @@index([tenantId, expiresAt])
  @@index([jobId])
  @@map("artifacts")
}

enum ArtifactType {
  brief
  meeting_pack
  voc_report
  competitor_report
  alignment_memo
  prd
  sprint_review
  release_notes
  prototype
  deck_content
}

// ============================================================================
// Source Models (for traceability)
// ============================================================================

model Source {
  id         String     @id @default(cuid())
  tenantId   String
  type       SourceType
  externalId String
  title      String
  url        String?
  content    String     @db.Text
  metadata   Json?
  fetchedAt  DateTime   @default(now())
  createdAt  DateTime   @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, type, externalId])
  @@index([tenantId, type])
  @@map("sources")
}

enum SourceType {
  slack_message
  jira_issue
  confluence_page
  gong_call
  zendesk_ticket
  community_post
  analytics_event
  competitor_page
  internal_doc
}

// ============================================================================
// Audit Log Models
// ============================================================================

model AuditLog {
  id           String      @id @default(cuid())
  tenantId     String
  userId       String?
  action       AuditAction
  resourceType String
  resourceId   String
  details      Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime    @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, resourceType, resourceId])
  @@index([userId])
  @@map("audit_logs")
}

enum AuditAction {
  job_created
  job_started
  job_completed
  job_failed
  job_cancelled
  tool_called
  tool_completed
  tool_failed
  proposal_created
  proposal_approved
  proposal_rejected
  artifact_created
  artifact_downloaded
  user_login
  user_logout
  permission_checked
  permission_denied
  connector_installed
  connector_oauth_completed
  subscription_created
  subscription_updated
  seat_assigned
  seat_unassigned
  sso_configured
  entitlement_updated
}

// ============================================================================
// Crawler Job Models
// ============================================================================

model CrawlerJob {
  id          String        @id @default(cuid())
  tenantId    String?
  userId      String?
  type        CrawlerType
  status      CrawlerStatus @default(pending)
  keywords    String[]
  platforms   String[]      @default([])
  config      Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  startedAt   DateTime?
  completedAt DateTime?
  error       String?

  results CrawlerResult[]

  @@index([tenantId, status])
  @@index([userId, createdAt])
  @@map("crawler_jobs")
}

enum CrawlerType {
  social
  web_search
  news
}

enum CrawlerStatus {
  pending
  running
  completed
  failed
}

model CrawlerResult {
  id        String   @id @default(cuid())
  jobId     String
  source    String
  title     String
  url       String?
  content   String   @db.Text
  author    String?
  publishedAt DateTime?
  sentiment String?
  metadata  Json?
  createdAt DateTime @default(now())

  job CrawlerJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@map("crawler_results")
}

// ============================================================================
// NextAuth Models
// ============================================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model AuthUser {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]

  @@map("auth_users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
